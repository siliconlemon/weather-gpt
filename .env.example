# OpenWeatherMap — https://openweathermap.org/api_keys
API_KEY=

BASE_URL=https://api.openweathermap.org/data/2.5
GEO_URL=https://api.openweathermap.org/geo/1.0

DEFAULT_UNITS=metric
DEFAULT_LANG=en

CACHE_TTL=600
MAX_DAILY_CALLS=1000

# LLM: stub | opencode_zen | openai | anthropic | gemini
LLM_PROVIDER=stub

# OpenCode Zen (OpenAI-compatible) — model IDs change; see:
# https://open-code.ai/docs/en/zen
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MODEL=glm-4.7-free
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=

# LLM HTTP: fail faster on rate limits / hangs (seconds); retries per SDK request
LLM_TIMEOUT=25
LLM_MAX_RETRIES=0
# Whole /api/chat turn including tools (thread wait; seconds)
CHAT_AGENT_TIMEOUT=120

FLASK_SECRET_KEY=change-me-in-production

# Optional: canonical / Open Graph absolute URLs when the public origin differs from the
# incoming request (e.g. behind a reverse proxy). No trailing slash. If unset, the app
# uses request.url_root.
# PUBLIC_SITE_URL=https://your.domain

# Dev-mode file logging (default off — use container/platform stdout in production)
LOG_TO_FILE=true
LOG_DIR=logs
# Deletes weather-gpt-YYYY-MM-DD.log (and old weather-gpt.log.YYYY-MM-DD) when that day is older than this many calendar days.
LOG_RETENTION_DAYS=7
LOG_LEVEL=INFO
